#include <stdio.h>
#define INF 9999

int main() {
    int n, i, j, u, v, min;
    scanf("%d", &n);

    int cost[n][n], dist[n], visited[n];

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    int src;
    scanf("%d", &src);

    for(i = 0; i < n; i++) {
        dist[i] = cost[src][i];
        visited[i] = 0;
    }

    visited[src] = 1;
    dist[src] = 0;

    for(i = 1; i < n; i++) {
        min = INF;
        for(j = 0; j < n; j++) {
            if(!visited[j] && dist[j] < min) {
                min = dist[j];
                u = j;
            }
        }

        visited[u] = 1;

        for(v = 0; v < n; v++) {
            if(!visited[v] && dist[u] + cost[u][v] < dist[v])
                dist[v] = dist[u] + cost[u][v];
        }
    }

    for(i = 0; i < n; i++)
        printf("%d ", dist[i]);

    return 0;
}
