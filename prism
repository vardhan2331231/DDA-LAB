#include <stdio.h>
#define INF 9999

int main() {
    int n, i, j, min, u, v;
    scanf("%d", &n);

    int cost[n][n], visited[n];

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    for(i = 0; i < n; i++)
        visited[i] = 0;

    visited[0] = 1;
    int edges = 0, total = 0;

    while(edges < n - 1) {
        min = INF;

        for(i = 0; i < n; i++) {
            if(visited[i]) {
                for(j = 0; j < n; j++) {
                    if(!visited[j] && cost[i][j] < min) {
                        min = cost[i][j];
                        u = i;
                        v = j;
                    }
                }
            }
        }

        printf("%d - %d : %d\n", u, v, min);
        total += min;
        visited[v] = 1;
        edges++;
    }

    printf("Total cost = %d", total);

    return 0;
}
