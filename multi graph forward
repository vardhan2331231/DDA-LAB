#include <stdio.h>
#define INF 9999

int main() {
    int n, i, j;
    scanf("%d", &n);

    int cost[n][n], dist[n];

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    for(i = 0; i < n; i++)
        dist[i] = INF;

    dist[0] = 0;

    for(i = 0; i < n; i++) {
        for(j = i + 1; j < n; j++) {
            if(cost[i][j] != INF && dist[i] + cost[i][j] < dist[j])
                dist[j] = dist[i] + cost[i][j];
        }
    }

    printf("%d", dist[n - 1]);

    return 0;
}
