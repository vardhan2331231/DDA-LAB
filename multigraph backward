#include <stdio.h>
#define INF 9999

int main() {
    int n, i, j;
    scanf("%d", &n);

    int cost[n][n], dist[n];

    for(i = 0; i < n; i++)
        for(j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);

    for(i = 0; i < n; i++)
        dist[i] = INF;

    dist[n - 1] = 0;

    for(i = n - 2; i >= 0; i--) {
        for(j = i + 1; j < n; j++) {
            if(cost[i][j] != INF && cost[i][j] + dist[j] < dist[i])
                dist[i] = cost[i][j] + dist[j];
        }
    }

    printf("%d", dist[0]);

    return 0;
}
